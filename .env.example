# --- LLM (generation) ---
# Get a key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here
# Model used to generate grounded answers. Any current Gemini model string works,
# e.g. gemini-2.5-flash (fast/cheap), gemini-3-pro-preview (higher quality).
GEMINI_MODEL=gemini-2.5-flash

# --- Embeddings (retrieval) ---
# Runs locally via sentence-transformers, no API key needed.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Vector store ---
VECTOR_STORE_PATH=./vector_store
VECTOR_STORE_COLLECTION=rag_docs

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# --- Retrieval ---
RETRIEVAL_TOP_K=4
# Cosine similarity distance threshold used to decide "not found in document".
# Lower = stricter. Range depends on FAISS distance metric (L2 here); tune after testing.
NOT_FOUND_DISTANCE_THRESHOLD=1.1

# --- App ---
DATA_DIR=./data/sample_inputs
APP_HOST=0.0.0.0
APP_PORT=8000
